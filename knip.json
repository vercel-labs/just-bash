{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/cli/just-bash.ts", "src/commands/js-exec/executor-adapter.ts"],
  "project": ["src/**/*.ts"],
  "ignore": [
    "src/**/*.test.ts",
    "src/spec-tests/**",
    "src/banned-patterns-test.ts",
    "src/security/fuzzing/**"
  ],
  "ignoreBinaries": ["tsx"],
  "rules": {
    "unlisted": "off",
    "unresolved": "off",
    "optionalPeerDependencies": "off",
    "types": "off"
  }
}
